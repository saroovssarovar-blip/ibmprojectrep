<!DOCTYPE html>
<html>
<head>
<title>AI Chatbot</title>
<style>
body{font-family:Arial;background:#f4f4f4}
.chat{width:350px;margin:50px auto;background:#fff;padding:10px;border-radius:10px}
.box{height:300px;overflow:auto}
input{width:70%;padding:8px}
button{padding:8px}
</style>
</head>
<body>
<div class="chat">
<div id="box" class="box"></div>
<input id="inp"><button onclick="send()">Send</button>
<p id="m"></p>
</div>
<script>
let p=[{n:"Nike Shoes",c:"shoes",pr:3000},{n:"Adidas Shoes",c:"shoes",pr:2000}];
let t=0,c=0;
function send(){
 let q=inp.value.toLowerCase(),s=performance.now(),r="No results";
 box.innerHTML+="<div>"+q+"</div>";
 if(q.includes("shoes")) r=p.map(x=>x.n+" ₹"+x.pr).join("<br>");
 if(q.includes("under")){
  let pr=q.match(/\d+/);
  r=p.filter(x=>x.pr<pr).map(x=>x.n).join("<br>")||"No results";
 } 
 let time=(performance.now()-s).toFixed(2);
 box.innerHTML+="<div style='color:green'>"+r+"</div>";
 
 t++; if(r!="No results") c++;
 m.innerHTML="Accuracy:"+(c/t*100).toFixed(1)+"% Time:"+time+"ms";
 inp.value="";
}
</script>

</body>
</html>
